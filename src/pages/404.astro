---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL ?? '';
---
<Layout title="404 — SCIE-PANC">
  <section class="not-found">
    <div class="container">
      <div class="nf-inner">
        <div class="nf-code">404</div>
        <h1>Page not found</h1>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <a href={`${base}/`} class="btn-back">← Back to home</a>
      </div>
    </div>
  </section>
</Layout>

<style>
.not-found {
  min-height: calc(100vh - var(--nav-h));
  display: flex;
  align-items: center;
  background: var(--navy);
  color: #fff;
}
.nf-inner { text-align: center; padding-block: 4rem; }
.nf-code {
  font-family: var(--font-display);
  font-size: 8rem;
  font-weight: 700;
  color: var(--blue-light);
  opacity: 0.3;
  line-height: 1;
  margin-bottom: 1rem;
}
h1 { color: #fff; font-size: 2.5rem; margin-bottom: 1rem; }
p { color: rgba(255,255,255,0.6); margin-bottom: 2rem; }
.btn-back {
  display: inline-flex;
  padding: 0.7rem 1.6rem;
  background: #fff;
  color: var(--navy);
  border-radius: 100px;
  font-weight: 600;
  text-decoration: none;
}
.btn-back:hover { opacity: 0.9; }
</style>
