---
// src/pages/publications.astro
import Layout from '../layouts/Layout.astro';

// Add real publications here as they are produced
const publications: {
  year: number;
  title: string;
  authors: string;
  journal: string;
  doi?: string;
}[] = [
  // Example structure:
  // {
  //   year: 2025,
  //   title: 'Spatial epigenomics reveals TME remodeling in PDAC',
  //   authors: 'Papantonis A, Javierre BM, Pancaldi V, et al.',
  //   journal: 'Nature Cancer',
  //   doi: 'https://doi.org/...',
  // },
];
---

<Layout title="SCIE-PANC — Publications">

  <section class="page-hero">
    <div class="container">
      <span class="section-label fade-up">Research output</span>
      <h1 class="page-title fade-up fade-up-d1">Publications</h1>
      <p class="page-subtitle fade-up fade-up-d2">
        Scientific articles, preprints, and data resources produced by the SCIE-PANC consortium.
      </p>
    </div>
  </section>

  <div class="divider"></div>

  <section class="pub-section">
    <div class="container">
      {publications.length === 0 ? (
        <div class="empty-state fade-up">
          <div class="empty-icon">📄</div>
          <h2>Publications coming soon</h2>
          <p>
            As the SCIE-PANC project progresses, scientific publications will be listed here. 
            Check back for updates or follow our GitHub repository.
          </p>
          <a href="https://github.com/SCIE-PANC" class="btn-primary-sm" target="_blank" rel="noopener">
            Follow on GitHub
          </a>
        </div>
      ) : (
        <div class="pub-list">
          {(() => {
            const years = [...new Set(publications.map(p => p.year))].sort((a, b) => b - a);
            return years.map(year => (
              <div class="pub-year-group">
                <h2 class="pub-year">{year}</h2>
                <ul class="pub-items">
                  {publications.filter(p => p.year === year).map((p, i) => (
                    <li class={`pub-item fade-up fade-up-d${Math.min(i+1,6)}`}>
                      <div class="pub-title">
                        {p.doi
                          ? <a href={p.doi} target="_blank" rel="noopener">{p.title}</a>
                          : p.title
                        }
                      </div>
                      <div class="pub-authors">{p.authors}</div>
                      <div class="pub-journal">{p.journal}</div>
                      {p.doi && (
                        <a href={p.doi} class="pub-doi" target="_blank" rel="noopener">
                          DOI →
                        </a>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            ));
          })()}
        </div>
      )}
    </div>
  </section>

</Layout>

<style>
.page-hero {
  background: var(--navy);
  padding-block: 5rem;
  color: #fff;
}
.page-title { font-size: clamp(2.5rem, 5vw, 4rem); color: #fff; margin-bottom: 1rem; }
.page-subtitle { font-size: 1.1rem; color: rgba(255,255,255,0.7); max-width: 56ch; line-height: 1.7; }

.pub-section { padding-block: 5rem; }

.empty-state {
  max-width: 480px;
  margin-inline: auto;
  text-align: center;
  padding: 4rem 2rem;
}
.empty-icon { font-size: 3.5rem; margin-bottom: 1.2rem; }
.empty-state h2 { font-size: 1.8rem; margin-bottom: 0.8rem; }
.empty-state p { color: var(--text-muted); line-height: 1.7; margin-bottom: 1.8rem; }
.btn-primary-sm {
  display: inline-flex;
  padding: 0.65rem 1.4rem;
  background: var(--navy);
  color: #fff;
  border-radius: 100px;
  font-weight: 600;
  font-size: 0.92rem;
  text-decoration: none;
  transition: background 0.2s;
}
.btn-primary-sm:hover { background: var(--navy-mid); }

.pub-year-group { margin-bottom: 3rem; }
.pub-year {
  font-size: 2rem;
  color: var(--navy);
  margin-bottom: 1.2rem;
  padding-bottom: 0.5rem;
  border-bottom: 2px solid var(--off-white);
}
.pub-items { list-style: none; display: flex; flex-direction: column; gap: 1.2rem; }
.pub-item {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 1.5rem;
}
.pub-title { font-weight: 700; font-size: 1.05rem; margin-bottom: 0.4rem; }
.pub-title a { color: var(--navy); text-decoration: none; }
.pub-title a:hover { text-decoration: underline; }
.pub-authors { font-size: 0.88rem; color: var(--text-muted); margin-bottom: 0.2rem; }
.pub-journal { font-size: 0.88rem; color: var(--blue); font-style: italic; margin-bottom: 0.6rem; }
.pub-doi {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--blue);
  text-decoration: none;
}
.pub-doi:hover { text-decoration: underline; }
</style>
