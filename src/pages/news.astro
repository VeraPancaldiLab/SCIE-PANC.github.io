---
// src/pages/news.astro
import Layout from '../layouts/Layout.astro';

// Placeholder news items — replace with real data as the project progresses
const newsItems = [
  // { date: '2025-01-15', title: 'Kick-off meeting held in Göttingen', excerpt: '...' },
];
---

<Layout title="SCIE-PANC — News">

  <section class="page-hero">
    <div class="container">
      <span class="section-label fade-up">Updates</span>
      <h1 class="page-title fade-up fade-up-d1">News</h1>
      <p class="page-subtitle fade-up fade-up-d2">
        Latest updates, publications, events, and announcements from the SCIE-PANC consortium.
      </p>
    </div>
  </section>

  <div class="divider"></div>

  <section class="news-section">
    <div class="container">
      {newsItems.length === 0 ? (
        <div class="empty-state fade-up">
          <div class="empty-icon">📡</div>
          <h2>Stay tuned</h2>
          <p>News and updates will appear here as the project progresses. Follow us on GitHub for the latest developments.</p>
          <a href="https://github.com/SCIE-PANC" class="btn-primary-sm" target="_blank" rel="noopener">
            Follow on GitHub
          </a>
        </div>
      ) : (
        <ul class="news-list">
          {newsItems.map((item, i) => (
            <li class={`news-item fade-up fade-up-d${Math.min(i+1,6)}`}>
              <time class="news-date">{item.date}</time>
              <h3 class="news-title">{item.title}</h3>
              <p class="news-excerpt">{item.excerpt}</p>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>

</Layout>

<style>
.page-hero {
  background: var(--navy);
  padding-block: 5rem;
  color: #fff;
}
.page-title { font-size: clamp(2.5rem, 5vw, 4rem); color: #fff; margin-bottom: 1rem; }
.page-subtitle { font-size: 1.1rem; color: rgba(255,255,255,0.7); max-width: 56ch; line-height: 1.7; }

.news-section { padding-block: 5rem; }

.empty-state {
  max-width: 480px;
  margin-inline: auto;
  text-align: center;
  padding: 4rem 2rem;
}
.empty-icon { font-size: 3.5rem; margin-bottom: 1.2rem; }
.empty-state h2 { font-size: 1.8rem; margin-bottom: 0.8rem; }
.empty-state p { color: var(--text-muted); line-height: 1.7; margin-bottom: 1.8rem; }
.btn-primary-sm {
  display: inline-flex;
  align-items: center;
  padding: 0.65rem 1.4rem;
  background: var(--navy);
  color: #fff;
  border-radius: 100px;
  font-weight: 600;
  font-size: 0.92rem;
  text-decoration: none;
  transition: background 0.2s;
}
.btn-primary-sm:hover { background: var(--navy-mid); }

.news-list { list-style: none; display: flex; flex-direction: column; gap: 1.5rem; }
.news-item {
  background: #fff;
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 1.8rem;
}
.news-date { font-size: 0.82rem; color: var(--blue); font-weight: 600; letter-spacing: 0.05em; }
.news-title { font-size: 1.2rem; margin-block: 0.4rem 0.6rem; }
.news-excerpt { color: var(--text-muted); line-height: 1.7; }
</style>
